# Copy this file to `sdkconfig.defaults.local` for private machine-specific
# settings. The local file is gitignored and can safely contain credentials.
#
# Example:
#   idf.py -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.local" build

CONFIG_DASHBOARD_WIFI_SSID="YOUR_WIFI_SSID"
CONFIG_DASHBOARD_WIFI_PASSWORD="YOUR_WIFI_PASSWORD"
CONFIG_DASHBOARD_HOSTNAME="fnos-dashboard"
CONFIG_DASHBOARD_STATIC_IP="192.168.1.222"
CONFIG_DASHBOARD_GATEWAY="192.168.1.1"
CONFIG_DASHBOARD_NETMASK="255.255.255.0"
CONFIG_DASHBOARD_DNS="192.168.1.1"
CONFIG_DASHBOARD_TIMEZONE="CST-8"
CONFIG_DASHBOARD_SNTP_SERVER="pool.ntp.org"
CONFIG_DASHBOARD_MQTT_URI="mqtt://192.168.1.214:1883"
CONFIG_DASHBOARD_MQTT_USERNAME="YOUR_MQTT_USERNAME"
CONFIG_DASHBOARD_MQTT_PASSWORD="YOUR_MQTT_PASSWORD"
CONFIG_DASHBOARD_MQTT_CLIENT_ID="fnos-dashboard"
CONFIG_DASHBOARD_MQTT_FNOS_CPU_TOPIC="esp32/fnos/cpu/state"
CONFIG_DASHBOARD_MQTT_FNOS_MEM_TOPIC="esp32/fnos/mem/state"
CONFIG_DASHBOARD_MQTT_FNOS_GPU_TOPIC="esp32/fnos/gpu/state"
CONFIG_DASHBOARD_MQTT_FNOS_TX_TOPIC="esp32/fnos/tx/state"
CONFIG_DASHBOARD_MQTT_FNOS_RX_TOPIC="esp32/fnos/rx/state"
CONFIG_DASHBOARD_MQTT_WIN_CPU_TOPIC="esp32/windows11/cpu/state"
CONFIG_DASHBOARD_MQTT_WIN_MEM_TOPIC="esp32/windows11/mem/state"
CONFIG_DASHBOARD_MQTT_WIN_GPU_TOPIC="esp32/windows11/gpu/state"
CONFIG_DASHBOARD_MQTT_WIN_TX_TOPIC="esp32/windows11/tx/state"
CONFIG_DASHBOARD_MQTT_WIN_RX_TOPIC="esp32/windows11/rx/state"
CONFIG_DASHBOARD_MQTT_WEATHER_TOPIC="esp32/dial/weather/state"
CONFIG_DASHBOARD_PHOTO_URL="http://192.168.1.212:8000/image.rgb565"
